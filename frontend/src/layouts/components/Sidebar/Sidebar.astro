---
import Profile from "./Profile.astro";
import RecentPosts from "./RecentPosts.astro";

interface Props {
  showRecentPosts?: boolean;
}

const { showRecentPosts = false } = Astro.props;
---

<aside>
  <Profile />
  {showRecentPosts && <RecentPosts />}
</aside>

<style>
  aside {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
</style>
