---
import Header from './components/Header.astro';
import Profile from './components/Profile.astro';

interface Props {
	title?: string;
	showRecentPosts?: boolean;
}

const { title = 'Blog', showRecentPosts = false } = Astro.props;

type BlogPost = {
	url: string;
	frontmatter: {
		title: string;
		pubDate: string;
	};
};

const postModules = import.meta.glob<BlogPost>('../pages/blog/*.md', { eager: true });
const recentPosts = Object.values(postModules)
	.sort((a, b) => Date.parse(b.frontmatter.pubDate) - Date.parse(a.frontmatter.pubDate))
	.slice(0, 3);
---

<!doctype html>
<html lang="ja">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="stylesheet" href="/styles/global.css">
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<div class="layout">
			<div class="site-header">
				<Header />
			</div>
			<main class="content">
				<slot />
			</main>
			<aside class="sidebar">
				<Profile />
				{showRecentPosts && (
					<section>
						<h2>最近の記事</h2>
						<ul>
							{recentPosts.map((post) => (
								<li><a href={post.url}>{post.frontmatter.title}</a></li>
							))}
						</ul>
					</section>
				)}
			</aside>
		</div>
	</body>
</html>

<style>
	.layout {
		display: grid;
		grid-template-columns: minmax(0, 1fr);
		grid-template-areas:
			'header'
			'content'
			'sidebar';
		gap: 1rem 2rem;
		margin: 0.5rem;
	}

	.site-header {
		grid-area: header;
	}

	.content {
		grid-area: content;
	}

	.sidebar {
		grid-area: sidebar;

		display: grid;
		gap: 1rem;
	}

	@media (min-width: 64rem) {
		.layout {
			grid-template-columns: minmax(0, 1fr) minmax(0, 42rem) 16rem minmax(0, 1fr);
			grid-template-areas:
				'. header . .'
				'. content sidebar .';
		}
	}
</style>
