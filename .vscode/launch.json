{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Development server",
      "request": "launch",
      "type": "node-terminal",
      "command": "./node_modules/.bin/astro dev",
      "cwd": "${workspaceFolder}/frontend",
      "serverReadyAction":{
        "action": "openExternally",
        "pattern": "Local    http://localhost:([0-9]+)",
        "uriFormat": "http://localhost:%s",
        "killOnServerStop": true
      }
    }
  ]
}
