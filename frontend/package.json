{
  "name": "blog",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@11.8.0",
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "26",
      "onFail": "warn"
    }
  },
  "scripts": {
    "dev": "astro dev",
    "check": "astro check",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "format": "prettier . --write",
    "format:check": "prettier . --check"
  },
  "dependencies": {
    "@astrojs/check": "0.9.9",
    "@astrojs/mdx": "7.0.0",
    "@astrojs/rss": "4.0.18",
    "@astrojs/sitemap": "3.7.3",
    "@microsoft/applicationinsights-web": "3.4.2",
    "astro": "7.0.2",
    "sharp": "0.35.2",
    "typescript": "6.0.3"
  },
  "devDependencies": {
    "prettier": "3.8.4",
    "prettier-plugin-astro": "0.14.1"
  }
}
