---
import { getRecentPosts } from '../../../helpers/blogPosts';

const recentPosts = getRecentPosts();
---

<section>
	<h2>最近の記事</h2>
	<ul>
		{recentPosts.map((post) => (
			<li><a href={post.url}>{post.frontmatter.title}</a></li>
		))}
	</ul>
</section>

<style>
	h2 {
		margin-bottom: 0.5rem;
	}
</style>
